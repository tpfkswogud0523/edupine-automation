# ============================================================
# K에듀파인 기안문 자동화 환경설정
# .env.example → 복사해서 .env 로 저장 후 값 입력
# ============================================================

# Claude AI API 키 (AI 자동 내용 생성 기능용 - 선택사항)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your_api_key_here

# 학교 정보 (AI가 기안문 작성 시 사용)
SCHOOL_NAME=효문고등학교
TEACHER_NAME=
DEPARTMENT=특수교육

# ──────────────────────────────────────────
# 자동 로그인 설정 (node main.js → 메뉴 5번)
# ──────────────────────────────────────────

# APKI 인증서 비밀번호 (대소문자 구분)
CERT_PASSWORD=your_cert_password_here

# 인증서 위치: 이동식디스크 | 하드디스크 | 저장토큰 | 보안토큰 | 휴대폰
CERT_LOCATION=이동식디스크

# Sentry error logging
SENTRY_DSN=
SENTRY_PROJECT=edupine-automation
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0
