# ============================================================
# K에듀파인 기안문 자동화 환경설정
# .env.example → 복사해서 .env 로 저장 후 값 입력
# ============================================================

# ※ 로그인 방식: 바탕화면 "에듀파인 자동화 Chrome" 바로가기로
#   Chrome 실행 후 공인인증서로 수동 로그인 (ID/PW 불필요)

# Claude AI API 키 (AI 자동 내용 생성 기능용 - 선택사항)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your_api_key_here

# 학교 정보 (AI가 기안문 작성 시 사용)
SCHOOL_NAME=효문고등학교
TEACHER_NAME=
DEPARTMENT=특수교육
